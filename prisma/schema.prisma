generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model News {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  publishedAt DateTime @default(now())
  authorId    Int
  type        String   @default("GENERAL")
  author      User     @relation("UserNews", fields: [authorId], references: [id])
}

model User {
  id                          Int                 @id @default(autoincrement())
  email                       String?             @unique
  password                    String?
  name                        String?
  memberType                  MemberType          @default(auditeur)
  accessLevel                 AccessLevel         @default(member)
  role                        String              @default("user")
  createdAt                   DateTime            @default(now())
  passwordNeedsChange         Boolean             @default(true)
  firstName                   String?
  lastName                    String?
  homePhone                   String?
  cellPhone                   String?
  gestconteNotes              String?
  gestconteId                 Int?
  nonProfitAffiliation        String?
  /// LEGACY: replaced by activityStatus + UserActivityEvent. For `db push`: keep
  /// this for the first push, run backfill.sql, THEN delete it and push again.
  isActive                    Boolean?            @default(true)
  activityStatus              UserActivityStatus  @default(ACTIVE)
  activityChangedAt           DateTime?
  /// LEGACY: superseded by UserActivityEvent history; no longer written. Refactor out.
  terminationDate             DateTime?
  /// LEGACY: superseded by UserActivityEvent.reason; no longer written. Refactor out.
  terminationReason           String?
  lastUpdated                 DateTime?           @updatedAt
  preferredDeliveryMethod     DeliveryMethod?
  paymentThreshold            Decimal?            @default(21.00) @db.Decimal(10, 2)
  currentBalance              Decimal?            @default(0.00) @db.Decimal(10, 2)
  preferredDistributionMethod String?
  isAvailable                 Boolean?            @default(true)
  availabilityNotes           String?
  specialization              String?
  maxConcurrentAssignments    Int?                @default(3)
  notes                       String?
  civilityId                  Int?
  civilityOther               String?
  addresses                   Address[]
  assignmentsProcessedBy      Assignment[]        @relation("AssignmentsProcessedBy")
  assignmentReaders           AssignmentReader[]
  bills                       Bill[]
  books                       Book[]
  CoupsDeCoeur                CoupsDeCoeur[]
  News                        News[]              @relation("UserNews")
  ordersAsAveugle             Orders[]            @relation("OrdersAsAveugle")
  ordersProcessedBy           Orders[]            @relation("OrdersProcessedBy")
  payments                    Payment[]
  billEventsPerformed         BillEvent[]         @relation("BillEventsPerformedBy")
  activityEvents              UserActivityEvent[] @relation("UserActivityEvents")
  activityEventsPerformed     UserActivityEvent[] @relation("UserActivityEventsBy")
  civility                    Civility?           @relation(fields: [civilityId], references: [id])
}

model Address {
  id                Int      @id @default(autoincrement())
  addressLine1      String?
  addressSupplement String?
  city              String?
  postalCode        String?
  stateProvince     String?
  country           String   @default("France")
  isDefault         Boolean  @default(false)
  userId            Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Book {
  id                     Int                 @id @default(autoincrement())
  title                  String
  author                 String
  publishedDate          DateTime?
  isbn                   String?             @unique
  description            String?
  available              Boolean             @default(true)
  createdAt              DateTime?           @default(now())
  updatedAt              DateTime            @updatedAt
  addedById              Int
  readingDurationMinutes Int?
  publisher              String?
  pageCount              Int?
  subtitle               String?
  audio_filepath         String?
  stock_date             DateTime?
  last_downloaded_date   DateTime?
  assignments            Assignment[]
  addedBy                User                @relation(fields: [addedById], references: [id])
  genres                 BookGenre[]
  CoupsDeCoeurBooks      CoupsDeCoeurBooks[]
  orders                 Orders[]
  source_access_id       Int?
  needsReview            Boolean             @default(false)
  id_arbre               Int?
  polly_audio_url        String?

  @@index([createdAt(sort: Desc)])
  @@index([title])
  @@index([author])
  @@index([isbn])
  @@index([available])
}

/// This model contains an expression index which requires additional setup for migrations. Visit https://pris.ly/d/expression-indexes for more info.
model Genre {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  description String?
  books       BookGenre[]

  @@index([name])
}

model Civility {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  sortOrder Int?
  isActive  Boolean @default(true)
  users     User[]

  @@index([name])
}

model CoupsDeCoeur {
  id          Int                 @id @default(autoincrement())
  title       String
  description String?
  audioPath   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  active      Boolean             @default(true)
  addedById   Int
  addedBy     User                @relation(fields: [addedById], references: [id])
  books       CoupsDeCoeurBooks[]
}

model CoupsDeCoeurBooks {
  coupsDeCoeurId Int
  bookId         Int
  book           Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  coupsDeCoeur   CoupsDeCoeur @relation(fields: [coupsDeCoeurId], references: [id])

  @@id([coupsDeCoeurId, bookId])
}

model BookGenre {
  bookId  Int
  genreId Int
  book    Book  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  genre   Genre @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([bookId, genreId])
  @@index([bookId])
  @@index([genreId])
}

model Status {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  sortOrder   Int?
  assignments Assignment[]
  orders      Orders[]

  @@index([name])
}

model MediaFormat {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(80)
  description String?  @db.VarChar(200)
  orders      Orders[]

  @@index([name])
}

model Bill {
  id               Int           @id @default(autoincrement())
  clientId         Int
  state            BillingStatus @default(BILLED)
  creationDate     DateTime
  issueDate        DateTime?
  paymentDate      DateTime?
  paymentReference String?
  invoiceAmount    Decimal       @db.Decimal(10, 2)
  isActive         Boolean       @default(true)
  deletedAt        DateTime?
  client           User          @relation(fields: [clientId], references: [id])
  orders           Orders[]
  payments         Payment[]
  events           BillEvent[]

  @@index([clientId])
  @@index([state])
  @@index([creationDate])
  @@index([isActive])
}

model Payment {
  id               Int            @id @default(autoincrement())
  clientId         Int?
  type             PaymentType
  amount           Decimal        @db.Decimal(10, 2)
  paymentMethod    PaymentMethod? // modepaiement_id from Access
  creationDate     DateTime
  issueDate        DateTime?
  paymentDate      DateTime?
  exportDate       DateTime?
  importDate       DateTime?
  receiptNumber    String? // num_recu
  fiscalite        String? // source type unclear – tighten to Boolean/enum after inspecting data
  cotisationYear   Int? // Annee_cotisation – only for type COTISATION
  comptable        String? // source type unclear – tighten after inspecting data
  isAllocated      Boolean? // Affectee
  allocationDate   DateTime? // date_affectation
  observations     String?
  billId           Int? // only for type ENREGISTREMENT
  sourceVenteId    Int? // raw idvente preserved for traceability
  sourceEcritureId Int? // raw idecriture (accounting entry) preserved
  isActive         Boolean        @default(true)
  deletedAt        DateTime?
  deletionReason   String? // Obs_Suppression
  client           User?          @relation(fields: [clientId], references: [id])
  bill             Bill?          @relation(fields: [billId], references: [id])

  @@index([clientId])
  @@index([type])
  @@index([billId])
  @@index([creationDate])
  @@index([cotisationYear])
  @@index([isActive])
}

model Orders {
  id                  Int                @id @default(autoincrement())
  aveugleId           Int
  catalogueId         Int
  requestReceivedDate DateTime
  statusId            Int
  isDuplication       Boolean
  mediaFormatId       Int
  deliveryMethod      DeliveryMethod
  processedByStaffId  Int?
  createdDate         DateTime?
  closureDate         DateTime?
  cost                Decimal?           @db.Decimal(10, 2)
  billingStatus       OrderBillingStatus @default(UNBILLED)
  billId              Int?
  lentPhysicalBook    Boolean
  notes               String?
  isActive            Boolean            @default(true)
  deletedAt           DateTime?
  updatedAt           DateTime?
  assignments         Assignment[]
  aveugle             User               @relation("OrdersAsAveugle", fields: [aveugleId], references: [id])
  bill                Bill?              @relation(fields: [billId], references: [id])
  catalogue           Book               @relation(fields: [catalogueId], references: [id])
  mediaFormat         MediaFormat        @relation(fields: [mediaFormatId], references: [id])
  processedByStaff    User?              @relation("OrdersProcessedBy", fields: [processedByStaffId], references: [id])
  status              Status             @relation(fields: [statusId], references: [id])

  @@index([aveugleId])
  @@index([catalogueId])
  @@index([statusId])
  @@index([billingStatus])
  @@index([mediaFormatId])
  @@index([billId])
  @@index([isActive])
}

model Assignment {
  id                 Int                @id @default(autoincrement())
  catalogueId        Int
  orderId            Int?
  receptionDate      DateTime?
  sentToReaderDate   DateTime?
  returnedToECADate  DateTime?
  statusId           Int
  notes              String?
  processedByStaffId Int?
  catalogue          Book               @relation(fields: [catalogueId], references: [id])
  order              Orders?            @relation(fields: [orderId], references: [id])
  processedByStaff   User?              @relation("AssignmentsProcessedBy", fields: [processedByStaffId], references: [id])
  status             Status             @relation(fields: [statusId], references: [id])
  readerHistory      AssignmentReader[]

  @@index([catalogueId])
  @@index([orderId])
  @@index([statusId])
}

model AssignmentReader {
  id           Int        @id @default(autoincrement())
  assignmentId Int
  readerId     Int
  assignedDate DateTime   @default(now())
  notes        String?
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  reader       User       @relation(fields: [readerId], references: [id])

  @@index([assignmentId])
  @@index([readerId])
  @@index([assignedDate])
}

enum DeliveryMethod {
  RETRAIT
  ENVOI
  NON_APPLICABLE
}

enum BillingStatus {
  DRAFT
  BILLED
  PAID
  SOLDE
}

enum OrderBillingStatus {
  UNBILLED
  BILLED
  UNBILLABLE
}

enum PaymentType {
  COTISATION
  ENREGISTREMENT
  DON
  DIVERS
}

enum PaymentMethod {
  CHEQUE // Chèque
  ESPECE // Espèce
  CB
  VIREMENT // Virement
  COMPTE_AUXI // Compte Auxi
}

enum MemberType {
  ecouteur // deprecated – remove once all records migrated
  auditeur
  lecteur
  informaticien
  administration
  bienfaiteur
}

enum AccessLevel {
  member
  admin
  super_admin
}

enum NewsType {
  GENERAL
  EVENEMENT
  ANNONCE
  ACTUALITE
  PROGRAMMATION
}

model BillEvent {
  id            Int            @id @default(autoincrement())
  billId        Int
  type          BillEventType
  fromState     BillingStatus?
  toState       BillingStatus?
  payload       Json?
  performedById Int?
  createdAt     DateTime       @default(now())
  bill          Bill           @relation(fields: [billId], references: [id], onDelete: Cascade)
  performedBy   User?          @relation("BillEventsPerformedBy", fields: [performedById], references: [id])

  @@index([billId])
  @@index([createdAt])
}

enum BillEventType {
  CREATED
  ISSUED
  REOPENED
  PAID
  SETTLED
  AMOUNT_CHANGED
  ORDER_ATTACHED
  ORDER_DETACHED
}

enum UserActivityStatus {
  ACTIVE
  INACTIVE
  ON_VACATION
  SUSPENDED
  DECEASED
  DEMISSION
  RADIATION
  PB_SANTE_MENTALE
}

/// Append-only history of a member's activity-status changes (who/what/when/why).
model UserActivityEvent {
  id          Int                 @id @default(autoincrement())
  userId      Int
  fromStatus  UserActivityStatus?
  toStatus    UserActivityStatus
  reason      String?
  comment     String?
  changedById Int?
  changedAt   DateTime            @default(now())
  user        User                @relation("UserActivityEvents", fields: [userId], references: [id])
  changedBy   User?               @relation("UserActivityEventsBy", fields: [changedById], references: [id])

  @@index([userId])
  @@index([changedAt])
}
